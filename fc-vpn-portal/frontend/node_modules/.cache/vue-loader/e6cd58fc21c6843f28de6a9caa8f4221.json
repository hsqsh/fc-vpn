{"remainingRequest":"C:\\Users\\20399\\Desktop\\fc-vpn\\fc-vpn-portal\\frontend\\node_modules\\vue-loader\\lib\\index.js??vue-loader-options!C:\\Users\\20399\\Desktop\\fc-vpn\\fc-vpn-portal\\frontend\\src\\components\\NetworkStatus.vue?vue&type=script&lang=js","dependencies":[{"path":"C:\\Users\\20399\\Desktop\\fc-vpn\\fc-vpn-portal\\frontend\\src\\components\\NetworkStatus.vue","mtime":1752138950716},{"path":"C:\\Users\\20399\\Desktop\\fc-vpn\\fc-vpn-portal\\frontend\\node_modules\\cache-loader\\dist\\cjs.js","mtime":1752144661109},{"path":"C:\\Users\\20399\\Desktop\\fc-vpn\\fc-vpn-portal\\frontend\\node_modules\\babel-loader\\lib\\index.js","mtime":1752144661275},{"path":"C:\\Users\\20399\\Desktop\\fc-vpn\\fc-vpn-portal\\frontend\\node_modules\\cache-loader\\dist\\cjs.js","mtime":1752144661109},{"path":"C:\\Users\\20399\\Desktop\\fc-vpn\\fc-vpn-portal\\frontend\\node_modules\\vue-loader\\lib\\index.js","mtime":1752144656723}],"contextDependencies":[],"result":[{"type":"Buffer","data":"base64:"},{"version":3,"sources":["NetworkStatus.vue"],"names":[],"mappings":";AAsCA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA","file":"NetworkStatus.vue","sourceRoot":"src/components","sourcesContent":["<template>\r\n  <b-card class=\"network-status\">\r\n    <template v-slot:header>\r\n      <h3 class=\"mb-0\">\r\n        <span>网络状态</span>\r\n        <b-spinner v-if=\"isConnecting\" small class=\"ml-2\" variant=\"primary\" label=\"正在连接...\"></b-spinner>\r\n      </h3>\r\n    </template>\r\n    \r\n    <b-row>\r\n      <b-col md=\"4\" class=\"font-weight-bold\">连接状态</b-col>\r\n      <b-col>\r\n        <b-badge :variant=\"statusVariant\">{{ statusText }}</b-badge>\r\n      </b-col>\r\n    </b-row>\r\n    \r\n    <b-row class=\"mt-2\">\r\n      <b-col md=\"4\" class=\"font-weight-bold\">服务ID</b-col>\r\n      <b-col>{{ serviceId || '无活动连接' }}</b-col>\r\n    </b-row>\r\n\r\n    <b-row class=\"mt-2\" v-if=\"isConnected\">\r\n      <b-col md=\"4\" class=\"font-weight-bold\">目标地址</b-col>\r\n      <b-col>{{ targetUrl }}</b-col>\r\n    </b-row>\r\n\r\n    <b-row class=\"mt-2\" v-if=\"isConnected\">\r\n      <b-col md=\"4\" class=\"font-weight-bold\">已连接时间</b-col>\r\n      <b-col>{{ connectedTime }}</b-col>\r\n    </b-row>\r\n\r\n    <template v-slot:footer v-if=\"isConnected\">\r\n      <b-button variant=\"danger\" size=\"sm\" @click=\"disconnect\">断开连接</b-button>\r\n    </template>\r\n  </b-card>\r\n</template>\r\n\r\n<script>\r\nexport default {\r\n  name: 'NetworkStatus',\r\n  props: {\r\n    isConnecting: {\r\n      type: Boolean,\r\n      default: false\r\n    },\r\n    isConnected: {\r\n      type: Boolean,\r\n      default: false\r\n    },\r\n    serviceId: {\r\n      type: String,\r\n      default: ''\r\n    },\r\n    targetUrl: {\r\n      type: String,\r\n      default: ''\r\n    },\r\n    connectedAt: {\r\n      type: Date,\r\n      default: null\r\n    }\r\n  },\r\n  computed: {\r\n    statusText() {\r\n      if (this.isConnecting) return '正在连接'\r\n      if (this.isConnected) return '已连接'\r\n      return '未连接'\r\n    },\r\n    statusVariant() {\r\n      if (this.isConnecting) return 'warning'\r\n      if (this.isConnected) return 'success'\r\n      return 'secondary'\r\n    },\r\n    connectedTime() {\r\n      if (!this.connectedAt) return ''\r\n      \r\n      const now = new Date()\r\n      const diffMs = now - this.connectedAt\r\n      const diffMins = Math.floor(diffMs / 60000)\r\n      const diffSecs = Math.floor((diffMs % 60000) / 1000)\r\n      \r\n      return `${diffMins}分钟 ${diffSecs}秒`\r\n    }\r\n  },\r\n  methods: {\r\n    disconnect() {\r\n      this.$emit('disconnect')\r\n    }\r\n  }\r\n}\r\n</script>\r\n"]}]}
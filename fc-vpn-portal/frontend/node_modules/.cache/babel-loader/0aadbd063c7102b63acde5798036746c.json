ror'\r\n    },\r\n    logout(state) {\r\n      state.status = ''\r\n      state.token = ''\r\n      state.user = {}\r\n    },\r\n    set_user(state, user) {\r\n      state.user = user\r\n    }\r\n  },\r\n  actions: {\r\n    login({ commit }, user) {\r\n      return new Promise((resolve, reject) => {\r\n        commit('auth_request')\r\n        axios.post('http://localhost:5000/api/auth/login', user)\r\n          .then(resp => {\r\n            const token = resp.data.access_token\r\n            localStorage.setItem('token', token)\r\n            axios.defaults.headers.common['Authorization'] = 'Bearer ' + token\r\n            commit('auth_success', token)\r\n            resolve(resp)\r\n          })\r\n          .catch(err => {\r\n            commit('auth_error')\r\n            localStorage.removeItem('token')\r\n            reject(err)\r\n          })\r\n      })\r\n    },\r\n    register({ commit }, user) {\r\n      return new Promise((resolve, reject) => {\r\n        commit('auth_request')\r\n        axios.post('http://localhost:5000/api/auth/register', user)\r\n          .then(resp => {\r\n            resolve(resp)\r\n          })\r\n          .catch(err => {\r\n            commit('auth_error')\r\n            reject(err)\r\n          })\r\n      })\r\n    },\r\n    logout({ commit }) {\r\n      return new Promise((resolve) => {\r\n        commit('logout')\r\n        localStorage.removeItem('token')\r\n        delete axios.defaults.headers.common['Authorization']\r\n        resolve()\r\n      })\r\n    },\r\n    fetchUserProfile({ commit }) {\r\n      return new Promise((resolve, reject) => {\r\n        axios.get('http://localhost:5000/api/user/profile')\r\n          .then(resp => {\r\n            commit('set_user', resp.data)\r\n            resolve(resp)\r\n          })\r\n          .catch(err => {\r\n            reject(err)\r\n          })\r\n      })    },\r\n    requestService(context, targetUrl) {\r\n      return new Promise((resolve, reject) => {\r\n        axios.post('http://localhost:5000/api/service/request', { target_url: targetUrl })\r\n          .then(resp => {\r\n            resolve(resp)\r\n          })\r\n          .catch(err => {\r\n            reject(err)\r\n          })\r\n      })\r\n    }\r\n  },\r\n  getters: {\r\n    isLoggedIn: state => !!state.token,\r\n    authStatus: state => state.status,\r\n    user: state => state.user\r\n  }\r\n})\r\n"],"mappings":"AAAA,OAAOA,GAAG,MAAM,KAAK;AACrB,OAAOC,IAAI,MAAM,MAAM;AACvB,OAAOC,KAAK,MAAM,OAAO;AAEzBF,GAAG,CAACG,GAAG,CAACF,IAAI,CAAC;AAEb,eAAe,IAAIA,IAAI,CAACG,KAAK,CAAC;EAC5BC,KAAK,EAAE;IACLC,MAAM,EAAE,EAAE;IACVC,KAAK,EAAEC,YAAY,CAACC,OAAO,CAAC,OAAO,CAAC,IAAI,EAAE;IAC1CC,IAAI,EAAE,CAAC;EACT,CAAC;EACDC,SAAS,EAAE;IACTC,YAAYA,CAACP,KAAK,EAAE;MAClBA,KAAK,CAACC,MAAM,GAAG,SAAS;IAC1B,CAAC;IACDO,YAAYA,CAACR,KAAK,EAAEE,KAAK,EAAE;MACzBF,KAAK,CAACC,MAAM,GAAG,SAAS;MACxBD,KAAK,CAACE,KAAK,GAAGA,KAAK;IACrB,CAAC;IACDO,UAAUA,CAACT,KAAK,EAAE;MAChBA,KAAK,CAACC,MAAM,GAAG,OAAO;IACxB,CAAC;IACDS,MAAMA,CAACV,KAAK,EAAE;MACZA,KAAK,CAACC,MAAM,GAAG,EAAE;MACjBD,KAAK,CAACE,KAAK,GAAG,EAAE;MAChBF,KAAK,CAACK,IAAI,GAAG,CAAC,CAAC;IACjB,CAAC;IACDM,QAAQA,CAACX,KAAK,EAAEK,IAAI,EAAE;MACpBL,KAAK,CAACK,IAAI,GAAGA,IAAI;IACnB;EACF,CAAC;EACDO,OAAO,EAAE;IACPC,KAAKA,CAAC;MAAEC;IAAO,CAAC,EAAET,IAAI,EAAE;MACtB,OAAO,IAAIU,OAAO,CAAC,CAACC,OAAO,EAAEC,MAAM,KAAK;QACtCH,MAAM,CAAC,cAAc,CAAC;QACtBjB,KAAK,CAACqB,IAAI,CAAC,sCAAsC,EAAEb,IAAI,CAAC,CACrDc,IAAI,CAACC,IAAI,IAAI;UACZ,MAAMlB,KAAK,GAAGkB,IAAI,CAACC,IAAI,CAACC,YAAY;UACpCnB,YAAY,CAACoB,OAAO,CAAC,OAAO,EAAErB,KAAK,CAAC;UACpCL,KAAK,CAAC2B,QAAQ,CAACC,OAAO,CAACC,MAAM,CAAC,eAAe,CAAC,GAAG,SAAS,GAAGxB,KAAK;UAClEY,MAAM,CAAC,cAAc,EAAEZ,KAAK,CAAC;UAC7Bc,OAAO,CAACI,IAAI,CAAC;QACf,CAAC,CAAC,CACDO,KAAK,CAACC,GAAG,IAAI;UACZd,MAAM,CAAC,YAAY,CAAC;UACpBX,YAAY,CAAC0B,UAAU,CAAC,OAAO,CAAC;UAChCZ,MAAM,CAACW,GAAG,CAAC;QACb,CAAC,CAAC;MACN,CAAC,CAAC;IACJ,CAAC;IACDE,QAAQA,CAAC;MAAEhB;IAAO,CAAC,EAAET,IAAI,EAAE;MACzB,OAAO,IAAIU,OAAO,CAAC,CAACC,OAAO,EAAEC,MAAM,KAAK;QACtCH,MAAM,CAAC,cAAc,CAAC;
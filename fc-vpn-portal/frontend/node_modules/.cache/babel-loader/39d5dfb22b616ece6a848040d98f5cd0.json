{"remainingRequest":"C:\\Users\\20399\\Desktop\\fc-vpn\\fc-vpn-portal\\frontend\\node_modules\\babel-loader\\lib\\index.js!C:\\Users\\20399\\Desktop\\fc-vpn\\fc-vpn-portal\\frontend\\node_modules\\cache-loader\\dist\\cjs.js??ref--1-0!C:\\Users\\20399\\Desktop\\fc-vpn\\fc-vpn-portal\\frontend\\node_modules\\vue-loader\\lib\\index.js??vue-loader-options!C:\\Users\\20399\\Desktop\\fc-vpn\\fc-vpn-portal\\frontend\\src\\views\\Dashboard.vue?vue&type=script&lang=js","dependencies":[{"path":"C:\\Users\\20399\\Desktop\\fc-vpn\\fc-vpn-portal\\frontend\\src\\views\\Dashboard.vue","mtime":1752155451999},{"path":"C:\\Users\\20399\\Desktop\\fc-vpn\\fc-vpn-portal\\frontend\\babel.config.js","mtime":1752145479680},{"path":"C:\\Users\\20399\\Desktop\\fc-vpn\\fc-vpn-portal\\frontend\\node_modules\\cache-loader\\dist\\cjs.js","mtime":1752144661109},{"path":"C:\\Users\\20399\\Desktop\\fc-vpn\\fc-vpn-portal\\frontend\\node_modules\\babel-loader\\lib\\index.js","mtime":1752144661275},{"path":"C:\\Users\\20399\\Desktop\\fc-vpn\\fc-vpn-portal\\frontend\\node_modules\\cache-loader\\dist\\cjs.js","mtime":1752144661109},{"path":"C:\\Users\\20399\\Desktop\\fc-vpn\\fc-vpn-portal\\frontend\\node_modules\\vue-loader\\lib\\index.js","mtime":1752144656723}],"contextDependencies":[],"result":[{"type":"Buffer","data":"base64:"},{"version":3,"names":["NetworkStatus","name","components","data","form","targetUrl","fields","key","label","error","success","loading","isConnected","currentServiceId","currentTargetUrl","connectedAt","computed","serviceHistory","$store","state","user","service_history","connectionDuration","now","Date","diffMs","Math","floor","methods","requestService","dispatch","then","response","service_id","proxy_url","setTimeout","window","open","refreshUserProfile","catch","err","message","finally","disconnectService","formatDate","dateString","date","toLocaleString","formatUptime","seconds","hours","minutes","secs","truncateUrl","url","length","substring","created"],"sources":["src/views/Dashboard.vue"],"sourcesContent":["<template>\r\n  <div class=\"dashboard\">\r\n    <b-container>\r\n      <h2 class=\"mb-4\">VPN 服务控制台</h2>\r\n      \r\n      <b-row>\r\n        <b-col md=\"8\">\r\n          <b-card>\r\n            <b-form @submit.prevent=\"requestService\">\r\n              <b-form-group\r\n                label=\"目标网址\"\r\n                label-for=\"target-url\"\r\n                description=\"请输入您想要访问的网址\"\r\n              >\r\n                <b-form-input\r\n                  id=\"target-url\"\r\n                  v-model=\"form.targetUrl\"\r\n                  type=\"text\"\r\n                  placeholder=\"例如: https://www.google.com\"\r\n                  required\r\n                ></b-form-input>\r\n              </b-form-group>\r\n\r\n              <b-button type=\"submit\" variant=\"primary\" :disabled=\"loading || isConnected\">\r\n                {{ loading ? '请求中...' : '发起服务请求' }}\r\n              </b-button>\r\n            </b-form>\r\n          </b-card>          <b-alert v-if=\"error\" variant=\"danger\" show class=\"mt-3\">{{ error }}</b-alert>\r\n          <b-alert v-if=\"success\" variant=\"success\" show class=\"mt-3\">{{ success }}</b-alert>\r\n          \r\n          <!-- 监控预览 -->\r\n          <b-card v-if=\"isConnected\" class=\"mt-4\">\r\n            <template v-slot:header>\r\n              <div class=\"d-flex justify-content-between align-items-center\">\r\n                <h5 class=\"mb-0\">服务监控概览</h5>\r\n                <b-button size=\"sm\" variant=\"outline-primary\" to=\"/monitor\">\r\n                  查看详细监控\r\n                </b-button>\r\n              </div>\r\n            </template>\r\n            <b-row>\r\n              <b-col md=\"3\" class=\"text-center\">\r\n                <h6 class=\"text-muted\">运行时间</h6>\r\n                <span class=\"h5\">{{ formatUptime(connectionDuration) }}</span>\r\n              </b-col>\r\n              <b-col md=\"3\" class=\"text-center\">\r\n                <h6 class=\"text-muted\">状态</h6>\r\n                <b-badge variant=\"success\" class=\"h6\">运行中</b-badge>\r\n              </b-col>\r\n              <b-col md=\"3\" class=\"text-center\">\r\n                <h6 class=\"text-muted\">服务ID</h6>\r\n                <small class=\"text-monospace\">{{ currentServiceId }}</small>\r\n              </b-col>\r\n              <b-col md=\"3\" class=\"text-center\">\r\n                <h6 class=\"text-muted\">目标</h6>\r\n                <small>{{ truncateUrl(currentTargetUrl) }}</small>\r\n              </b-col>\r\n            </b-row>\r\n          </b-card>\r\n        </b-col>\r\n        \r\n        <b-col md=\"4\">\r\n          <NetworkStatus \r\n            :isConnecting=\"loading\"\r\n            :isConnected=\"isConnected\"\r\n            :serviceId=\"currentServiceId\"\r\n            :targetUrl=\"currentTargetUrl\"\r\n            :connectedAt=\"connectedAt\"\r\n            @disconnect=\"disconnectService\"\r\n          />\r\n        </b-col>\r\n      </b-row>\r\n\r\n      <b-card class=\"mt-4\">\r\n        <template v-slot:header>\r\n          <h3 class=\"mb-0\">最近的服务请求</h3>\r\n        </template>\r\n        <b-table \r\n          :items=\"serviceHistory\" \r\n          :fields=\"fields\"\r\n          responsive=\"sm\"\r\n          striped\r\n          hover\r\n          v-if=\"serviceHistory.length > 0\"\r\n        >\r\n          <template v-slot:cell(timestamp)=\"data\">\r\n            {{ formatDate(data.value) }}\r\n          </template>\r\n        </b-table>\r\n        <p v-else>暂无服务请求记录</p>\r\n      </b-card>\r\n    </b-container>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nimport NetworkStatus from '@/components/NetworkStatus.vue'\r\n\r\nexport default {\r\n  name: 'Dashboard',\r\n  components: {\r\n    NetworkStatus\r\n  },\r\n  data() {\r\n    return {\r\n      form: {\r\n        targetUrl: ''\r\n      },\r\n      fields: [\r\n        { key: 'service_id', label: '服务ID' },\r\n        { key: 'target', label: '目标网址' },\r\n        { key: 'timestamp', label: '请求时间' },\r\n        { key: 'status', label: '状态' },\r\n        { key: 'cost', label: '费用 ($)' }\r\n      ],\r\n      error: null,\r\n      success: null,\r\n      loading: false,\r\n      isConnected: false,\r\n      currentServiceId: '',\r\n      currentTargetUrl: '',\r\n      connectedAt: null\r\n    }\r\n  },  computed: {\r\n    serviceHistory() {\r\n      return this.$store.state.user.service_history || []\r\n    },\r\n    connectionDuration() {\r\n      if (!this.connectedAt) return 0\r\n      const now = new Date()\r\n      const diffMs = now - this.connectedAt\r\n      return Math.floor(diffMs / 1000) // 返回秒数\r\n    }\r\n  },\r\n  methods: {    requestService() {\r\n      this.loading = true\r\n      this.error = null\r\n      this.success = null\r\n        this.$store.dispatch('requestService', this.form.targetUrl)\r\n        .then(response => {\r\n          const data = response.data\r\n          this.success = `服务请求已创建，服务ID: ${data.service_id}`\r\n          \r\n          // 保存当前连接信息\r\n          this.isConnected = true\r\n          this.currentServiceId = data.service_id\r\n          this.currentTargetUrl = this.form.targetUrl\r\n          this.connectedAt = new Date()\r\n          \r\n          // 自动跳转到代理URL\r\n          if (data.proxy_url) {\r\n            this.success += ` - 正在跳转到目标网站...`\r\n            setTimeout(() => {\r\n              // 在新窗口中打开代理URL\r\n              window.open(data.proxy_url, '_blank')\r\n            }, 1000)\r\n          }\r\n          \r\n          this.form.targetUrl = ''\r\n          this.refreshUserProfile()\r\n        }).catch(err => {\r\n          this.error = (err.response && err.response.data && err.response.data.message) || '请求服务失败，请稍后重试'\r\n        })\r\n        .finally(() => {\r\n          this.loading = false\r\n        })\r\n    },\r\n      disconnectService() {\r\n      if (!this.currentServiceId) {\r\n        return\r\n      }\r\n      \r\n      this.$store.dispatch('disconnectService', this.currentServiceId)\r\n        .then(() => {\r\n          this.isConnected = false\r\n          this.currentServiceId = ''\r\n          this.currentTargetUrl = ''\r\n          this.connectedAt = null\r\n          this.success = '已成功断开连接'\r\n          this.refreshUserProfile()\r\n        })\r\n        .catch(err => {\r\n          this.error = (err.response && err.response.data && err.response.data.message) || '断开连接失败'\r\n        })\r\n    },\r\n    refreshUserProfile() {\r\n      this.$store.dispatch('fetchUserProfile')\r\n    },    formatDate(dateString) {\r\n      const date = new Date(dateString)\r\n      return date.toLocaleString()\r\n    },\r\n    formatUptime(seconds) {\r\n      const hours = Math.floor(seconds / 3600)\r\n      const minutes = Math.floor((seconds % 3600) / 60)\r\n      const secs = seconds % 60\r\n      \r\n      if (hours > 0) {\r\n        return `${hours}时${minutes}分${secs}秒`\r\n      } else if (minutes > 0) {\r\n        return `${minutes}分${secs}秒`\r\n      } else {\r\n        return `${secs}秒`\r\n      }\r\n    },\r\n    truncateUrl(url) {\r\n      return url && url.length > 30 ? url.substring(0, 30) + '...' : url\r\n    }\r\n  },\r\n  created() {\r\n    this.refreshUserProfile()\r\n  }\r\n}\r\n</script>\r\n"],"mappings":"AAgGA,OAAAA,aAAA;AAEA;EACAC,IAAA;EACAC,UAAA;IACAF;EACA;EACAG,KAAA;IACA;MACAC,IAAA;QACAC,SAAA;MACA;MACAC,MAAA,GACA;QAAAC,GAAA;QAAAC,KAAA;MAAA,GACA;QAAAD,GAAA;QAAAC,KAAA;MAAA,GACA;QAAAD,GAAA;QAAAC,KAAA;MAAA,GACA;QAAAD,GAAA;QAAAC,KAAA;MAAA,GACA;QAAAD,GAAA;QAAAC,KAAA;MAAA,EACA;MACAC,KAAA;MACAC,OAAA;MACAC,OAAA;MACAC,WAAA;MACAC,gBAAA;MACAC,gBAAA;MACAC,WAAA;IACA;EACA;EAAAC,QAAA;IACAC,eAAA;MACA,YAAAC,MAAA,CAAAC,KAAA,CAAAC,IAAA,CAAAC,eAAA;IACA;IACAC,mBAAA;MACA,UAAAP,WAAA;MACA,MAAAQ,GAAA,OAAAC,IAAA;MACA,MAAAC,MAAA,GAAAF,GAAA,QAAAR,WAAA;MACA,OAAAW,IAAA,CAAAC,KAAA,CAAAF,MAAA;IACA;EACA;EACAG,OAAA;IAAAC,eAAA;MACA,KAAAlB,OAAA;MACA,KAAAF,KAAA;MACA,KAAAC,OAAA;MACA,KAAAQ,MAAA,CAAAY,QAAA,wBAAA1B,IAAA,CAAAC,SAAA,EACA0B,IAAA,CAAA
      <b-form-group\r\n                label=\"目标网址\"\r\n                label-for=\"target-url\"\r\n                description=\"请输入您想要访问的网址\"\r\n              >\r\n                <b-form-input\r\n                  id=\"target-url\"\r\n                  v-model=\"form.targetUrl\"\r\n                  type=\"text\"\r\n                  placeholder=\"例如: https://www.google.com\"\r\n                  required\r\n                ></b-form-input>\r\n              </b-form-group>\r\n\r\n              <b-button type=\"submit\" variant=\"primary\" :disabled=\"loading || isConnected\">\r\n                {{ loading ? '请求中...' : '发起服务请求' }}\r\n              </b-button>\r\n            </b-form>\r\n          </b-card>\r\n\r\n          <b-alert v-if=\"error\" variant=\"danger\" show class=\"mt-3\">{{ error }}</b-alert>\r\n          <b-alert v-if=\"success\" variant=\"success\" show class=\"mt-3\">{{ success }}</b-alert>\r\n        </b-col>\r\n        \r\n        <b-col md=\"4\">\r\n          <NetworkStatus \r\n            :isConnecting=\"loading\"\r\n            :isConnected=\"isConnected\"\r\n            :serviceId=\"currentServiceId\"\r\n            :targetUrl=\"currentTargetUrl\"\r\n            :connectedAt=\"connectedAt\"\r\n            @disconnect=\"disconnectService\"\r\n          />\r\n        </b-col>\r\n      </b-row>\r\n\r\n      <b-card class=\"mt-4\">\r\n        <template v-slot:header>\r\n          <h3 class=\"mb-0\">最近的服务请求</h3>\r\n        </template>\r\n        <b-table \r\n          :items=\"serviceHistory\" \r\n          :fields=\"fields\"\r\n          responsive=\"sm\"\r\n          striped\r\n          hover\r\n          v-if=\"serviceHistory.length > 0\"\r\n        >\r\n          <template v-slot:cell(timestamp)=\"data\">\r\n            {{ formatDate(data.value) }}\r\n          </template>\r\n        </b-table>\r\n        <p v-else>暂无服务请求记录</p>\r\n      </b-card>\r\n    </b-container>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nimport NetworkStatus from '@/components/NetworkStatus.vue'\r\n\r\nexport default {\r\n  name: 'Dashboard',\r\n  components: {\r\n    NetworkStatus\r\n  },\r\n  data() {\r\n    return {\r\n      form: {\r\n        targetUrl: ''\r\n      },\r\n      fields: [\r\n        { key: 'service_id', label: '服务ID' },\r\n        { key: 'target', label: '目标网址' },\r\n        { key: 'timestamp', label: '请求时间' },\r\n        { key: 'status', label: '状态' },\r\n        { key: 'cost', label: '费用 ($)' }\r\n      ],\r\n      error: null,\r\n      success: null,\r\n      loading: false,\r\n      isConnected: false,\r\n      currentServiceId: '',\r\n      currentTargetUrl: '',\r\n      connectedAt: null\r\n    }\r\n  },\r\n  computed: {\r\n    serviceHistory() {\r\n      return this.$store.state.user.service_history || []\r\n    }\r\n  },\r\n  methods: {    requestService() {\r\n      this.loading = true\r\n      this.error = null\r\n      this.success = null\r\n      \r\n      this.$store.dispatch('requestService', this.form.targetUrl)\r\n        .then(response => {\r\n          this.success = `服务请求已创建，服务ID: ${response.data.service_id}`\r\n          \r\n          // 保存当前连接信息\r\n          this.isConnected = true\r\n          this.currentServiceId = response.data.service_id\r\n          this.currentTargetUrl = this.form.targetUrl\r\n          this.connectedAt = new Date()\r\n          \r\n          this.form.targetUrl = ''\r\n          this.refreshUserProfile()\r\n        })\r\n        .catch(err => {\r\n          this.error = err.response?.data?.message || '请求服务失败，请稍后重试'\r\n        })\r\n        .finally(() => {\r\n          this.loading = false\r\n        })\r\n    },\r\n    \r\n    disconnectService() {\r\n      this.isConnected = false\r\n      this.currentServiceId = ''\r\n      this.currentTargetUrl = ''\r\n      this.connectedAt = null\r\n      this.success = '已成功断开连接'\r\n      \r\n      // 在真实场景中，这里会调用API来断开VPN连接\r\n      // this.$store.dispatch('disconnectService', this.currentServiceId)\r\n    },\r\n    refreshUserProfile() {\r\n      this.$store.dispatch('fetchUserProfile')\r\n    },\r\n    formatDate(dateString) {\r\n      const date = new Date(dateString)\r\n      return date.toLocaleString()\r\n    }\r\n  },\r\n  created() {\r\n    this.refreshUserProfile()\r\n  }\r\n}\r\n</script>\r\n"],"mappings":"AAoEA,OAAAA,aAAA;AAEA;EACAC,IAAA;EACAC,UAAA;IACAF;EACA;EACAG,KAAA;IACA;MACAC,IAAA;QACAC,SAAA;MACA;MACAC,MAAA,GACA;QAAAC,GAAA;QAAAC,KAAA;MAAA,GACA;QAAAD,GAAA;QAAAC,KAAA;MAAA,GACA;QAAAD,GAAA;QAAAC,KAAA;MAAA,GACA;QAAAD,GAAA;QAAAC,KAAA;MAAA,GACA;QAAAD,GAAA;QAAAC,KAAA;MAAA,EACA;MACAC,KAAA;MACAC,OAAA;MACAC,OAAA;MACAC,WAAA;MACAC,gBAAA;MACAC,gBAAA;MACAC,WAAA;IACA;EACA;EACAC,QAAA;IACAC,eAAA;MACA,YAAAC,MAAA,CAAAC,KAAA,CAAAC,IAAA,CAAAC,eAAA;IACA;EACA;EACAC,OAAA;IAAAC,eAAA;MACA,KAAAZ,OAAA;MACA,KAAAF,KAAA;MACA,KAAAC,OAAA;MAEA,KAAAQ,MAAA,CAAAM,QAAA,wBAAApB,IAAA,CAAAC,SAAA,EACAoB,IAAA,CAAAC,QAAA;QACA,KAAAhB,OAAA,oBAAAgB,QAAA,CAAAvB,IAAA,CAAAwB,UAAA;;QAEA;QACA,KAAAf,WAAA;QACA,KAAAC,gBAAA,GAAAa,QAAA,CAAAvB,IAAA,CAAAwB,UAAA;QACA,KAAAb,gBAAA,QAAAV,IAAA,CAAAC,SAAA;QACA,KAAAU,WAAA,OAAAa,IAAA;QAEA,KAAAxB,IAAA,CAAAC,SAAA;QACA,KAAAwB,kBAAA;MACA,GACAC,KAAA,CAAAC,GAAA;QACA,KAAAtB,KAAA,GAAAsB,GAAA,CAAAL,QAAA,EAAAvB,IAAA,EAAA6B,OAAA;MACA,GACAC,OAAA;QACA,KAAAtB,OAAA;MACA;IACA;IAEAuB,kBAAA;MACA,KAAAtB,WAAA;MACA,KAAAC,gBAAA;MACA,KAAAC,gBAAA;MACA,KAAAC,WAAA;MACA,KAAAL,OAAA;;MAEA;MACA;IACA;IACAmB,mBAAA;MACA,KAAAX,MAAA,CAAAM,QAAA;IACA;IACAW,WAAAC,UAAA;MACA,MAAAC,IAAA,OAAAT,IAAA,CAAAQ,UAAA;MACA,OAAAC,IAAA,CAAAC,cAAA;IACA;EACA;EACAC,QAAA;IACA,KAAAV,kBAAA;EACA;AACA","ignoreList":[]}]}